{
  "name": "jmc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @jmc/db generate",
    "db:migrate": "pnpm --filter @jmc/db migrate",
    "db:push": "pnpm --filter @jmc/db push"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5"
  }
}
