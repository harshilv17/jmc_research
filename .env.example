# ── Database (packages/db, apps/api) ─────────────────────────────────────────
DATABASE_URL=postgres://jmc:jmc@localhost:5432/jmc

# ── API server (apps/api) ────────────────────────────────────────────────────
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# public base URL used to build uploaded-image links
API_PUBLIC_URL=http://localhost:4000

# ── Frontends (apps/web, apps/admin) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
API_URL=http://localhost:4000/v1

# ── Admin auth (apps/admin) ──────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Admin seed (pnpm --filter @jmc/api seed:admin) ───────────────────────────
ADMIN_EMAIL=admin@jatinmalikcouture.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Atelier Admin
